package app

import (
	"net/http"

	"github.com/gin-gonic/gin"
	swaggerFiles "github.com/swaggo/files"
	ginSwagger "github.com/swaggo/gin-swagger"

	userModule "{{ .Title }}/internal/module/user"
	"{{ .Title }}/internal/pkg/response"

	_ "{{ .Title }}/docs"
)

// registerHTTPRoutes 统一挂载所有 HTTP 路由。
// 应用层只负责装配和注册，不处理具体业务逻辑。
func (a *App) registerHTTPRoutes() {
	a.Gin.GET("/health", func(c *gin.Context) {
		c.JSON(http.StatusOK, response.Success("ok"))
	})

	v1 := a.Gin.Group("/api/v1")

	userModule.RegisterHTTP(v1, userModule.Dependencies{
		DB: a.DB.GetDB(),
	})

	a.Gin.GET("/swagger/*any", ginSwagger.WrapHandler(swaggerFiles.Handler))
}
